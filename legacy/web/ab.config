project: tuyotools-frontend
language: javascript
framework: angularjs
version: "1.4.14"

source_dirs:
  - app/app/
  - app/assets/scss/

test_dirs:
  - test/

entry_points:
  - app/index.html
  - app/app/app.js
  - app/app/routers.js
  - app/deploy_config.js

build:
  tool: grunt
  config: Gruntfile.js
  commands:
    serve: grunt serve
    build: grunt build --force
    test: grunt test
    lint: grunt jshint

package_managers:
  - name: npm
    config: package.json
    lock: null
  - name: bower
    config: bower.json
    lock: null

ci:
  platform: gitlab
  config: .gitlab-ci.yml

technologies:
  - angularjs
  - ui-router
  - bootstrap-3
  - scss
  - compass
  - socket-io
  - facebook-sdk
  - google-maps
  - grunt
  - bower
  - karma
  - jasmine

modules:
  - name: TuyoTools
    path: app/app/app.js
    type: root
  - name: landing
    path: app/app/pages/landing/
    type: feature
  - name: dashboard
    path: app/app/pages/dashboard/
    type: feature
  - name: user
    path: app/app/pages/user/
    type: feature
  - name: post
    path: app/app/post/
    type: feature
  - name: creation
    path: app/app/create/createDonation/
    type: feature
  - name: createAppreciation
    path: app/app/create/createAppreciation/
    type: feature
  - name: calification
    path: app/app/calification/
    type: feature
  - name: forumModule
    path: app/app/contact/forums/
    type: feature
  - name: chat
    path: app/app/contact/privateChat/
    type: feature
  - name: publicForum
    path: app/app/contact/publicForum/
    type: feature
  - name: notifications
    path: app/app/notifications/
    type: feature
  - name: help
    path: app/app/help/
    type: feature
  - name: map
    path: app/app/map/
    type: feature
  - name: modal
    path: app/app/modals/
    type: feature
  - name: navigationBar
    path: app/app/layouts/navigationBar/
    type: feature
  - name: footer
    path: app/app/layouts/footer/
    type: feature
  - name: loadingModule
    path: app/app/loading/
    type: feature
  - name: popups
    path: app/app/popUps/
    type: feature
  - name: reports
    path: app/app/reports/
    type: feature
  - name: staticPagesModule
    path: app/app/pages/staticPages/
    type: feature
  - name: tuyoAux
    path: app/app/extras/
    type: utility

services:
  - path: app/app/scripts/services/api.js
    role: http-client
  - path: app/app/scripts/services/auth.js
    role: authentication
  - path: app/app/scripts/services/config.js
    role: configuration
  - path: app/app/scripts/services/facebook.js
    role: oauth
  - path: app/app/scripts/services/authorizer.js
    role: authorization
    status: legacy-unused
  - path: app/app/app.service.js
    role: global-state
  - path: app/app/socket.service.js
    role: realtime

environments:
  - name: development_local
    backend: "http://localhost:8000"
  - name: development_out
    backend: "https://devapi.tuyo.uy"
  - name: test
    backend: "https://testapi.tuyo.uy"
  - name: production
    backend: "https://api.tuyo.uy"

deploy:
  strategy: branch-based
  branches:
    devel: development
    test: test
    master: production
  target: /var/www/tuyo_tools/www/
