language: python-django
technologies:
  - python
  - django
  - django-rest-framework
  - postgresql
test_framework: pytest
package_manager: pip
install_command: pip install -r requirements.txt
dev_command: python manage.py runserver
dev_port: 8000
test_command: python manage.py test
build_command: python manage.py check --deploy
lint_command: python manage.py check
database: postgresql://localhost:5432/tuyo-v2
